{
  "version": 2,
  "routes": [
    { "src": "/api/news", "dest": "/api/news.js" },
    { "src": "/api/intelligence", "dest": "/api/intelligence.js" },
    { "src": "/api/country", "dest": "/api/country.js" },
    { "src": "/api/threats", "dest": "/api/threats.js" },
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/api/aircraft", "dest": "/api/aircraft.js" },
    { "src": "/api/analyst", "dest": "/api/analyst.js" },
    { "src": "/api/naval", "dest": "/api/naval.js" },
    { "src": "/api/tts", "dest": "/api/tts.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/analyst.js": { "maxDuration": 30 },
    "api/country.js": { "maxDuration": 30 },
    "api/naval.js": { "maxDuration": 30 },
    "api/tts.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
